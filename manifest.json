{
  "manifest_version": 3,
  "name": "TabBrain",
  "version": "0.1.0",
  "description": "Smart tab triage — auto-detects duplicates, clusters by topic, cleans stale tabs, keeps a rescue list.",
  "permissions": ["tabs", "storage", "notifications", "bookmarks"],
  "background": { "scripts": ["background.js"] },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": { "48": "icons/icon-48.svg", "96": "icons/icon-96.svg" },
    "default_title": "TabBrain"
  },
  "icons": { "48": "icons/icon-48.svg", "96": "icons/icon-96.svg" }
}
